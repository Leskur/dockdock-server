{
  "name": "dockdock-server",
  "version": "0.0.1",
  "description": "Default image download service for DockDock Agent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/sea-bundle.js && node --experimental-sea-config sea-config.json"
  },
  "keywords": ["docker", "image", "proxy", "dockdock"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
